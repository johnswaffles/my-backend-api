[application]
config/name="Cozy Village"
run/main_scene="res://scenes/main.tscn"

[display]
window/size/viewport_width=1280
window/size/viewport_height=720
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="canvas_items"

[rendering]
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/default_filters/use_nearest_mipmap_filter=false
environment/defaults/default_clear_color=Color(0.72, 0.82, 0.68, 1)

[input]
orbit_left={"deadzone":0.5,"events":[Object(InputEventKey,"physical_keycode":81)]}
orbit_right={"deadzone":0.5,"events":[Object(InputEventKey,"physical_keycode":69)]}

